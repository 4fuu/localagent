{% extends "base.html.jinja" %}

{% block extra_styles %}
  .hero { padding: 22px 28px; border-bottom: 1px solid #f3f4f6; }
  .eyebrow { font-size: 12px; color: #94a3b8; letter-spacing: 0.08em; text-transform: uppercase; }
  .name { margin-top: 6px; font-size: 22px; font-weight: 800; color: #1f2937; }
  .price { margin-top: 6px; font-size: 24px; font-weight: 700; color: {{ theme.primary }}; }
{% endblock %}

{% block body %}
  <div class="hero"><div class="eyebrow">Car Pro</div><div class="name">{{ car_name }}</div>{% if car_price %}<div class="price">{{ car_price }}</div>{% endif %}</div>
  {% for label, value in rows %}
  <div class="row"><div class="label">{{ label }}</div><div class="value">{{ value }}</div></div>
  {% endfor %}
{% endblock %}
