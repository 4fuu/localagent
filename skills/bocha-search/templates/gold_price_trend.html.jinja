{% extends "base.html.jinja" %}

{% block extra_styles %}
  .gold-section {
    padding: 22px 28px 18px;
    border-bottom: 1px solid #f3f4f6;
  }
  .gold-section:last-of-type {
    border-bottom: none;
  }
  .gold-section-title {
    font-size: 13px;
    font-weight: 700;
    color: #6b7280;
    letter-spacing: 0.06em;
    margin-bottom: 10px;
  }
  .gold-price-line {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .gold-price {
    font-size: 34px;
    line-height: 1;
    font-weight: 800;
    color: {{ theme.primary }};
  }
  .gold-unit {
    font-size: 14px;
    color: #9ca3af;
  }
  .gold-change {
    margin-top: 8px;
    font-size: 15px;
    font-weight: 700;
  }
  .metric-up {
    color: #ef4444;
  }
  .metric-down {
    color: #22c55e;
  }
  .metric-flat {
    color: #6b7280;
  }
  .gold-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 16px;
  }
  .gold-metric {
    background: #f8fafc;
    border-radius: 12px;
    padding: 12px 14px;
  }
  .gold-metric-name {
    font-size: 12px;
    color: #6b7280;
    margin-bottom: 6px;
  }
  .gold-metric-value {
    font-size: 16px;
    font-weight: 700;
  }
{% endblock %}

{% block body %}
  {% for section in gold_sections %}
  <div class="gold-section">
    <div class="gold-section-title">{{ section.title }}</div>
    <div class="gold-price-line">
      <div class="gold-price">{{ section.price }}</div>
      {% if section.unit %}<div class="gold-unit">{{ section.unit }}</div>{% endif %}
    </div>
    {% if section.change %}<div class="gold-change {{ section.change_color }}">{{ section.change }}</div>{% endif %}
    {% if section.metrics %}
    <div class="gold-metrics">
      {% for metric in section.metrics %}
      <div class="gold-metric">
        <div class="gold-metric-name">{{ metric.name }}</div>
        <div class="gold-metric-value {{ metric.color }}">{{ metric.value }}</div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endfor %}

  {% for label, value in rows %}
  <div class="row">
    <div class="label">{{ label }}</div>
    <div class="value">{{ value }}</div>
  </div>
  {% endfor %}
{% endblock %}
