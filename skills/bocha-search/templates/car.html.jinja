{% extends "base.html.jinja" %}

{% block extra_styles %}
  .car-hero {
    padding: 20px 28px;
    border-bottom: 1px solid #f3f4f6;
  }
  .car-name {
    font-size: 20px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 4px;
  }
  .car-price {
    font-size: 24px;
    font-weight: 700;
    color: {{ theme.primary }};
  }
  .car-price-unit {
    font-size: 14px;
    font-weight: 400;
    color: #9ca3af;
  }
  .car-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .car-grid .row {
    border-right: 1px solid #f3f4f6;
  }
  .car-grid .row:nth-child(2n) {
    border-right: none;
  }
{% endblock %}

{% block body %}
  {% if car_name is defined %}
  <div class="car-hero">
    <div class="car-name">{{ car_name }}</div>
    {% if car_price %}<div class="car-price">{{ car_price }} <span class="car-price-unit">万元</span></div>{% endif %}
  </div>
  {% endif %}
  {% if rows %}
  <div class="car-grid">
    {% for label, value in rows %}
    <div class="row">
      <div class="label">{{ label }}</div>
      <div class="value">{{ value }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
{% endblock %}
