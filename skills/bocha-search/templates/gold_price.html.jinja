{% extends "base.html.jinja" %}

{% block extra_styles %}
  .hero { padding: 24px 28px; border-bottom: 1px solid #f3f4f6; text-align: center; }
  .name { font-size: 14px; color: #6b7280; }
  .price { margin-top: 8px; font-size: 36px; font-weight: 800; color: {{ theme.primary }}; }
  .change { margin-top: 6px; font-size: 15px; font-weight: 700; }
  .metal-up { color: #ef4444; }
  .metal-down { color: #22c55e; }
  .metal-flat { color: #6b7280; }
{% endblock %}

{% block body %}
  <div class="hero">
    <div class="name">{{ metal_name }}</div>
    <div class="price">{{ metal_price }}</div>
    {% if metal_change %}<div class="change {{ metal_color }}">{{ metal_change }}</div>{% endif %}
  </div>
  {% for label, value in rows %}
  <div class="row"><div class="label">{{ label }}</div><div class="value">{{ value }}</div></div>
  {% endfor %}
{% endblock %}
