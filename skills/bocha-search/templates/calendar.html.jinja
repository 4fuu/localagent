{% extends "base.html.jinja" %}

{% block extra_styles %}
  .cal-hero {
    padding: 24px 28px;
    text-align: center;
    border-bottom: 1px solid #f3f4f6;
  }
  .cal-solar {
    font-size: 36px;
    font-weight: 700;
    color: {{ theme.primary }};
  }
  .cal-lunar {
    font-size: 16px;
    color: #6b7280;
    margin-top: 4px;
  }
  .cal-week {
    font-size: 14px;
    color: #9ca3af;
    margin-top: 2px;
  }
{% endblock %}

{% block body %}
  {% if cal_solar is defined %}
  <div class="cal-hero">
    <div class="cal-solar">{{ cal_solar }}</div>
    {% if cal_lunar %}<div class="cal-lunar">{{ cal_lunar }}</div>{% endif %}
    {% if cal_week %}<div class="cal-week">{{ cal_week }}</div>{% endif %}
  </div>
  {% endif %}
  {% for label, value in rows %}
  <div class="row">
    <div class="label">{{ label }}</div>
    <div class="value">{{ value }}</div>
  </div>
  {% endfor %}
{% endblock %}
