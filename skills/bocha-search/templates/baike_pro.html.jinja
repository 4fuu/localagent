{% extends "base.html.jinja" %}

{% block extra_styles %}
  .hero { padding: 22px 28px; border-bottom: 1px solid #f3f4f6; }
  .hero-title { font-size: 22px; font-weight: 800; color: #1f2937; }
  .hero-desc { margin-top: 10px; font-size: 14px; line-height: 1.7; color: #4b5563; }
{% endblock %}

{% block body %}
  <div class="hero">
    <div class="hero-title">{{ baike_title }}</div>
    {% if baike_desc %}<div class="hero-desc">{{ baike_desc }}</div>{% endif %}
  </div>
  {% for label, value in rows %}
  <div class="row">
    <div class="label">{{ label }}</div>
    <div class="value">{{ value }}</div>
  </div>
  {% endfor %}
{% endblock %}
