{% extends "base.html.jinja" %}

{% block extra_styles %}
  .med-hero {
    padding: 20px 28px;
    border-bottom: 1px solid #f3f4f6;
  }
  .med-title {
    font-size: 20px;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 8px;
  }
  .med-desc {
    font-size: 14px;
    color: #4b5563;
    line-height: 1.7;
  }
  .med-warning {
    margin: 12px 28px;
    padding: 10px 16px;
    background: #fef2f2;
    border-radius: 8px;
    font-size: 12px;
    color: #b91c1c;
    line-height: 1.5;
  }
{% endblock %}

{% block body %}
  {% if med_title is defined %}
  <div class="med-hero">
    <div class="med-title">{{ med_title }}</div>
    {% if med_desc %}<div class="med-desc">{{ med_desc }}</div>{% endif %}
  </div>
  {% endif %}
  {% for label, value in rows %}
  <div class="row">
    <div class="label">{{ label }}</div>
    <div class="value">{{ value }}</div>
  </div>
  {% endfor %}
  <div class="med-warning">⚠️ 以上内容仅供参考，不构成医疗建议。如有健康问题，请咨询专业医生。</div>
{% endblock %}
