{% extends "base.html.jinja" %}

{% block extra_styles %}
  .oil-grid {
    padding: 12px 20px 16px;
  }
  .oil-item {
    background: #f8fafc;
    border-radius: 12px;
    padding: 14px 20px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .oil-item:last-child { margin-bottom: 0; }
  .oil-type {
    font-size: 15px;
    font-weight: 600;
    color: #1f2937;
  }
  .oil-price {
    font-size: 20px;
    font-weight: 700;
    color: {{ theme.primary }};
  }
  .oil-unit {
    font-size: 12px;
    color: #9ca3af;
    font-weight: 400;
  }
{% endblock %}

{% block body %}
  {% if oil_items %}
  <div class="oil-grid">
    {% for item in oil_items %}
    <div class="oil-item">
      <span class="oil-type">{{ item.name }}</span>
      <span class="oil-price">{{ item.price }} <span class="oil-unit">元/升</span></span>
    </div>
    {% endfor %}
  </div>
  {% else %}
    {% for label, value in rows %}
    <div class="row">
      <div class="label">{{ label }}</div>
      <div class="value">{{ value }}</div>
    </div>
    {% endfor %}
  {% endif %}
{% endblock %}
